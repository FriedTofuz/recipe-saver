# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# Supabase — find these in your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key — SERVER ONLY, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Groq (free tier: 14,400 req/day) — SERVER ONLY
# Get your key at https://console.groq.com
GROQ_API_KEY=gsk_...

# Edamam Nutrition Analysis API — SERVER ONLY
# Get credentials at https://developer.edamam.com/
EDAMAM_APP_ID=your_app_id
EDAMAM_APP_KEY=your_app_key

# Optional: Firecrawl for URL import fallback — SERVER ONLY
# FIRECRAWL_API_KEY=fc-...
